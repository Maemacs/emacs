;; Stuff youll be interested in
;; 1. :init - stuff here is usually for setting configuration variables
;;
;; 2. ./user-lisp/user-kallie.el
;;  - Note if you edit this file and there is a user-kallie.elc - you need to recompile the file
;;    with:
;;      :elisp-byte-compile-file or M-x elisp-byte-compile-file
;;
;; 3. Dont know what something does? run:
;;   :xref-find-definitions or M-x xref-find-definitions
;;   :describe-function or M-x describe-function
;;   :describe-variable or M-x describe-variable
;;   :describe-mode or M-x describe-mode
;;   while you have the cursor over the item
;;
;; 4. Is the theme a bit odd? No worries! customize it with
;;   :describe-theme or M-x describe-theme
;; and click / press enter on the [customize] keyword
;;
;; 5. type C-h h
;;
;; 6. C-x f, C-x C-f, and C-x C-b are your best friends
;;
;; 7. search: -alpha 70
;;    For the background transparency value
;;
;; 8.
;;   :increase-font-size or M-x increase-font-size
;;   :decrease-font-size or M-x decrease-font-size
;;   :use-stream-font-size or M-x use-stream-font-size
;;   :use-normal-font-size or M-x use-normal-font-size

;; User lisp packages
(add-hook 'after-init-hook
  (lambda ()
    ;; Non lisp packages
    (use-package magit :ensure t)
    (use-package multiple-cursors :ensure t)
    (use-package web-mode :ensure t)
    (use-package evil :ensure t
      :init (defvar evil-mode-buffers '()
	            "Evil has a bug in current version where this isnt defined in emacs v31"))
    (use-package ido)
    (use-package epa-file)
    (use-package org)
    (use-package project)
    (use-package compile)
    (use-package gruvbox-theme :ensure t
      :config
      ;; This is the closest theme to 'melange' that I could find for emacs sadly.
      ;; BUT! You can configure the theme to 'behave' like 'melange' in terms of highlighting
      ;; by configuring what colors are used for functions, keywords, etc
      ;; Customiez the theme through the 'custom-theme-set-faces below
      ;; Or use :customize-face <face> to customize the face you want
      ;;   'face's are font faces, its the word for every cell
      ;;           If you want to know what the face is called, you can use :describe-face -
      ;;           the face at the current cursor position will be displayed as the first option to select from
      ;; I (zoftie) would be happy to send you a video showing an example how to do this
      ;;   (its much simpler than it seems)
      ;; Alternatively - 'melpa' can be added as a possible repository, and there is a doom-ayu theme
      ;; Which is available in doom-themes - WARNING, if you try out 'doom' emacs - it will overwrite core emacs files.
      (load-theme 'gruvbox-dark-hard t)
      
      (custom-theme-set-faces
        'gruvbox-dark-hard
        '(line-number ((t (:foreground "#7c6f64" :background nil))))
        '(line-number-current-line ((t (:foreground "#fe8019" :background nil)))))

      ;; Set the background transparency - doesnt work on macos or windows
      ;; If this isnt working on linux, you are probably building emacs without the --with-cairo configuration
      (let ((-alpha 70))
        (set-frame-parameter nil 'alpha-background -alpha)
        (add-to-list 'default-frame-alist (cons 'alpha-background -alpha))))

    ;;  в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЎӨв –вўІвЎҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ
    ;;  в Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈҖв Өв –в ’в ӣв үв үв үв ӣв »вўҰвЎҖв ҲвЎҮв ҖвўҖвЎҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ
    ;;  в Җв Җв Җв Җв ҖвўҖвЎӨв һв үв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҷв ҰвЈҝв ҖвЎҸвЎ¬вЈҚвЈІвЎӨв Өв Өв Өв Өв ӨвЈҖвЎҖв Җв Җв Җв Җв Җв Җв Җв Җ
    ;;  вўҖвЎӨв –в ҡвўүв Ҹв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҳвЎ„вЎ§в ҹв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв ҷв ҰвЈҖв Җв Җв Җв Җв Җ
    ;;  в ҷвЈ·в …вўҖвЎҺв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЎҖвўҖв Җв ҖвЎҝв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв ів Өв Өвў„вЈҖ
    ;;  в Җв ҳвЈҰвЈёв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҫвЈҝв Ӣв Җв  вЎҮв ҖвЎҫв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўұвЎҲвЎҶвЎҹ
    ;;  в Җв Җв ҲвЎҸв Җв Җв Җв Җв Җв Җв  вЈҝвЈ·в Җв °вЎҸвў»в үв ҖвўёвЎҖв Җв ҖвЎҮв Җвў№вЈҝвўҶвўҖвЎҖв Җв Җв Җв Җвў вЎҖв Җв Җв Җв Җв Җв ҹвЎјв Ғ
    ;;  в Җв Җв ҖвЈ§в Җв Җв Җв Җв Җв Җв Җв үв үв Җв Җв ёвЈёвЎҶв Җв Җв Ғв Җв ҖвЎҮв Җвў°вЎҮв Ҳв үв ӣв Ӯв ёвЈҝв Ҷв Ҳв Ғв Җв Җв Җв Җв ҖвЎҹв Җв Җ
    ;;  в Җв Җв ҖвўёвЎҶв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв үв Ғв Җв Җв Җв Җв ҖвЎҮв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў вЎҮв Җв Җ
    ;;  в Җв Җв Җв ҖвўҝвЈ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЎҙв ўв §в Өв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвўёв Җв Җв Җ
    ;;  в Җв Җв Җв Җв Җв ӣв ҝвЈҰвЈҖвЈҖвЈ вЈӨвЈӨв –в Җв Җв Җв Җв Җв җвўҰвЈівЈ„вЎҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ в Үв Җв Җв Җ
    ;;  в Җв Җв Җв Җв Җв Җв Җв Җв Җв үвЈ°вЎҝв ғв Җв Җв Җв Җв Җв Җвўўв Җв Ҳв үвў»вЎ—в Ӯв Җв Җв Җв Җв Җв Җв ҷв ІвЈ¶в Ұв Өв ”в ҡв Ғв Җв Җв Җв Җ
    ;;  в Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ°вЈ»в Ғв Җв Җв Җв Җв Җв Җв Җв ҲвЈүвЈҷв ҡвЎҹв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҲвўҰв Җв Җв Җв Җв Җв Җв Җв Җ
    ;;  в Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҝв Үв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҲвўұвЎҹв ІвЎҙв ’в Ів Ҷв Җв Җв Җв Җв Җв Җв ҲвЎҮв Җв Җв Җв Җв Җв Җв Җ
    ;;  в Җв Җв Җв Җв Җв Җв ҖвўҖвЎһв »вЎ„вЈ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ӣв ўвЎёв Ғв Җв Җв Җв Җв Җв Җв Җв ҖвЎҖвЎёв »вЎҖв Җв Җв Җв Җв Җв Җ
    ;;  в Җв Җв Җв Җв Җв Җв Җв Ҳвў·вЈ„в ҷв ҡв ӣвўівЎӨвЈҰвЈ„вЈ°вЈҙв ¶в ¶в ҙв ¶в јв ·в ¶в Өв Өв Өв Өв Өв ҰвўҙвЎӢв үв ҒвЈ°в ғв Җв Җв Җв Җв Җв Җ
    ;;  в Җв Җв Җв Җв Җв Җв Җв Җв Җв үв “в ’в ҡв үв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв үв үв үв Җв Җв Җв Җв Җв Җв Җв Җ

    (setq user-display-font "PxPlus IBM VGA8")
    (setq user-display-font-size 28)
    (setq user-display-stream-font-size-modifier 20)
    (setq using-elisp-italics nil)
    (setq using-ripgrep nil)
    (setq use-evil-mode 1)
    (setq truncate-lines nil)

    ;; Load all the user files
    (mapcar 'load (directory-files "~/.config/emacs/user" t ".el"))

    (add-to-list 'project-switch-commands '(project-npm "npm" "n"))
    (global-set-key (kbd "C-x p n") 'project-npm)
    (setq project-switch-commands
        '((project-find-file "Find file")
           (project-find-regexp "Find regexp")
           (project-find-dir "Find directory")
           ;; (project-magit-status "Magit" "m") TODO: Fix project selection
           (project-eshell "Eshell")
